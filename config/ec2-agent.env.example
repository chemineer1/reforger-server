# Optional: send one Discord message per EC2 boot when A2S first responds,
# which means the game server is reachable instead of only container-started.
# DISCORD_READY_WEBHOOK_URL=https://discord.com/api/webhooks/...
# DISCORD_READY_MESSAGE=Arma Reforger server is online and ready to join.

# Safer default from the systemd unit: failed player-count checks do not count
# as idle. Set to 1 if you want a broken or unreachable local server to stop
# the instance after startup grace plus the idle threshold.
# IDLE_ON_QUERY_FAILURE=0
